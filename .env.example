# ═══════════════════════════════════════════════════════════
# AI Claim Monorepo — Environment Template
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ─── Azure OpenAI (shared by ai_claim + pathway + azure-proxy) ───
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_API_VERSION=2024-06-01

# ─── ai_claim specific ──────────────────────────────────
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# ─── Pathway specific ───────────────────────────────────
AZURE_EMBEDDINGS_ENDPOINT=https://your-embeddings.cognitiveservices.azure.com/
AZURE_EMBEDDINGS_API_KEY=your_embeddings_api_key
MODEL1=gpt-4o-mini
MODEL2=gpt-5-mini
TEMPERATURE=0.1

# ─── Azure Proxy specific ───────────────────────────────
AZURE_DEPLOYMENT_NAME=gpt-5-mini
GLM_MODEL_NAME=GLM-5-Turbo
GLM_MODEL_VERSION=2024-06-01
GLM_API_KEY=your_glm_api_key
PROXY_PORT=8009

# ─── Gemini (optional) ──────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
