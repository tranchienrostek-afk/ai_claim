# Azure OpenAI chat
AZURE_OPENAI_ENDPOINT=https://your-chat-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-chat-api-key
AZURE_OPENAI_API_VERSION=2024-06-01

# Azure OpenAI embeddings
AZURE_EMBEDDINGS_ENDPOINT=https://your-embeddings-resource.cognitiveservices.azure.com/
AZURE_EMBEDDINGS_API_KEY=your-embeddings-api-key

# Optional explicit embedding deployment name.
# If omitted, the semantic RAG pipeline will fall back to `text-embedding-3-large`.
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# Model names / deployments used elsewhere in the project
MODEL1=gpt-4o-mini
MODEL2=gpt-5-mini
TEMPERATURE=0.1

# Optional alternative provider
GEMINI_API_KEY=your-gemini-api-key

# Neo4j (override for Docker if needed)
# NEO4J_URI=bolt://localhost:7688
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=password123

# Optional ICD auto-coding API used as fallback for unresolved disease -> ICD matching
ICD_AUTO_CODE_URL=http://10.14.190.28:8000/api/v1/icd/auto-code
ICD_AUTO_CODE_ENABLED=1
ICD_AUTO_CODE_TIMEOUT_SEC=20
ICD_AUTO_CODE_MIN_CONFIDENCE=0.7
